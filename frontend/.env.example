# ─────────────────────────────────────────────────────────────
# LawMitran Frontend (Next.js App Router) — environment template
# Copy to frontend/.env.local:  cp frontend/.env.example frontend/.env.local
# Next.js auto-loads frontend/.env.local for local development.
# NEXT_PUBLIC_* values are inlined at BUILD time and exposed to the browser —
# never put secrets here. This app owns its config — it does NOT read a root .env.
# ─────────────────────────────────────────────────────────────

# Backend API base URL (used by lib/api/* and helpers)
# Default if unset: http://localhost:3001/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Canonical site URL for SEO metadata, sitemap, robots, JSON-LD
# Default if unset: https://www.lawmitran.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps JavaScript API key (lawyer search map).
# Optional — leave blank to render the search without the map.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
