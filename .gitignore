# ─────────────────────────────────────────────
# LawMitran — root .gitignore (npm monorepo)
# App-specific rules also live in backend/, frontend/, infra/terraform/
# ─────────────────────────────────────────────

# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.*

# Build output
dist/
build/
out/
.next/
*.tsbuildinfo

# Environment / secrets
# Each app owns its own env; there is no root .env anymore.
.env
.env.*
backend/.env
frontend/.env.local
# Keep templates tracked
!.env.example
!.env.*.example
!backend/.env.example
!frontend/.env.example
*.pem
*.key
secrets.*

# Prisma generated client
**/generated/prisma/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/

# Local data volumes (self-hosted stack)
pgdata/
minio-data/
redis-data/
docker/**/data/

# Caches
.cache/
.turbo/
.eslintcache

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE / editor
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*~

# Terraform (see infra/terraform/.gitignore for full rules)
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
*.tfplan

# Misc
*.tgz
.vercel
# Temporary UI experiments
sample-ui/
