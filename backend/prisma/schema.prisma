generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// RBAC-lite: sub-role for ADMIN users. SUPER can do everything;
// OPS = verification/users/moderation; FINANCE = plans/offers/transactions.
enum AdminRole {
  SUPER
  OPS
  FINANCE
}

enum Role {
  CLIENT
  LAWYER
  ADMIN
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum LeadStatus {
  NEW
  ASSIGNED
  CONTACTED
  CLOSED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

enum OfferDiscountType {
  PERCENT
  FLAT
}

enum ContactCategory {
  PAYMENT_ISSUE
  ID_CARD_UPLOAD_ISSUE
  ACCOUNT_ISSUE
  SUBSCRIPTION_ISSUE
  LEAD_ISSUE
  VERIFICATION_ISSUE
  TECHNICAL_ISSUE
  OTHER
}

enum ContactQueryStatus {
  OPEN
  RESOLVED
}

enum AwardType {
  CLIENTS_CHOICE
  TOP_RESPONDER
  RISING_STAR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DocumentStatus {
  DRAFT
  GENERATED
  PAID
  DELIVERED
}

enum DeliveryType {
  DIGITAL
  ESTAMP
  PHYSICAL
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  mobile       String   @unique
  passwordHash String
  fullName     String? // display name from signup (lawyers also keep Lawyer.fullName as per Bar Council)
  role         Role     @default(CLIENT)
  adminRole          AdminRole? // only meaningful when role = ADMIN
  adminOtpHash       String? // 2FA login code (sha256), short-lived
  adminOtpExpiresAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Consent trail (DPDP): captured at signup, withdrawable via settings/account deletion.
  termsAcceptedAt DateTime? // Terms of Use & Privacy Policy
  consentAt       DateTime? // personal-data processing (identity verification + lawyer matching)
  marketingOptIn  Boolean   @default(false) // optional updates/offers via email/SMS/WhatsApp

  emailVerified              Boolean   @default(false)
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?

  mobileVerified       Boolean   @default(false)
  mobileOtpHash        String? // SHA-256 of the OTP (never the raw code)
  mobileOtpExpiresAt   DateTime?
  mobileOtpAttempts    Int       @default(0) // failed verify attempts in the current cycle
  mobileOtpLockedUntil DateTime? // set after too many failed attempts
  mobileOtpLastSentAt  DateTime? // for resend throttling

  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?

  // change-mobile flow: OTP is sent to pendingMobile; on verify it becomes `mobile`
  pendingMobile String?

  avatarUrl String?
  status    UserStatus @default(ACTIVE)
  deletedAt DateTime? // soft delete

  lawyer          Lawyer?
  leads           Lead[]             @relation("ClientLeads")
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]     @relation("AuditActor")
  propertyCases   PropertyCase[]
  ratings         Rating[]
  documents       CustomerDocument[]
  bookmarks       Bookmark[]
  notifications   Notification[]
  reportsMade     Report[]           @relation("Reporter")
  reportsAgainst  Report[]           @relation("ReportedUser")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ReportStatus {
  OPEN
  REVIEWING
  ACTIONED
  DISMISSED
}

// Two-sided reporting: a client can report a lawyer and a lawyer can report a client
// (usually about a specific contacted lead). Admin reviews and acts.
model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reporter       User         @relation("Reporter", fields: [reporterId], references: [id])
  reportedUserId String
  reportedUser   User         @relation("ReportedUser", fields: [reportedUserId], references: [id])
  leadId         String? // optional context: the lead they were in contact over
  reason         String // FAKE_PROFILE, MISCONDUCT, SPAM, NO_SHOW, ABUSIVE, WRONG_INFO, OTHER
  details        String?
  status         ReportStatus @default(OPEN)
  adminNote      String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([reportedUserId, status])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Lawyer {
  id                   String  @id @default(uuid())
  userId               String  @unique
  user                 User    @relation(fields: [userId], references: [id])
  fullName             String
  slug                 String? @unique // SEO URL: /lawyer/:slug (generated at approval)
  barCouncilNumber     String  @unique
  barCouncilState      String
  experienceYears      Int
  gender               Gender?
  bio                  String?
  profileImageUrl      String?
  certificateImageUrl  String

  cityId String?
  city   City?   @relation(fields: [cityId], references: [id])

  latitude  Float?
  longitude Float?

  ratingAvg   Decimal? @db.Decimal(3, 2)
  ratingCount Int      @default(0)

  verificationStatus VerificationStatus @default(PENDING)
  approvedBy         String?
  approvedAt         DateTime?

  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialStartDate     DateTime           @default(now())
  trialEndDate       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  verifications Verification[]
  subscriptions Subscription[]
  leads         Lead[]               @relation("LawyerLeads")
  ratings       Rating[]
  awards        LawyerAward[]
  payments      Payment[]
  practiceAreas LawyerPracticeArea[]
  languages     LawyerLanguage[]
  courts        LawyerCourt[]
  bookmarkedBy  Bookmark[]
  offices       LawyerOffice[]
  serviceAreas  LawyerServiceArea[]

  @@index([cityId, verificationStatus])
}

model Verification {
  id           String             @id @default(uuid())
  lawyerId     String
  lawyer       Lawyer             @relation(fields: [lawyerId], references: [id])
  documentType String
  documentUrl  String
  status       VerificationStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  comments     String?
  createdAt    DateTime           @default(now())
}

model Subscription {
  id        String             @id @default(uuid())
  lawyerId  String
  lawyer    Lawyer             @relation(fields: [lawyerId], references: [id])
  planName  String
  amount    Decimal            @db.Decimal(10, 2)
  startDate DateTime
  endDate   DateTime
  status    SubscriptionStatus

  @@index([lawyerId, status])
}

model SubscriptionPlanPrice {
  planName        String   @id
  amount          Decimal  @db.Decimal(10, 2)
  monthlyLeadCap  Int? // max new leads a lawyer on this plan receives per month; null = unlimited
  maxServiceAreas Int? // max active service areas (docs/28); null = unlimited
  updatedAt       DateTime @updatedAt
}

// Duration-based pricing: one row per (plan, duration). Lets a lawyer buy a plan
// for 30 days / 3 months / 6 months / 1 year, each at its own (usually discounted) price.
model SubscriptionPlanTier {
  id           String   @id @default(uuid())
  planName     String // BASIC | PREMIUM
  durationDays Int // 30, 90, 180, 365
  label        String // "30 days", "3 months", "6 months", "1 year"
  amount       Decimal  @db.Decimal(10, 2)
  active       Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  @@unique([planName, durationDays])
  @@index([planName, active])
}

// Seasonal / promotional offers (e.g. Diwali, Pongal, Republic Day) configured by admin.
// Auto-applied at checkout: best active offer matching the (plan, duration) wins.
// planName null = all plans; durationDays null = all durations.
model Offer {
  id            String            @id @default(uuid())
  name          String // e.g. "Diwali Offer"
  description   String?
  discountType  OfferDiscountType @default(PERCENT)
  discountValue Decimal           @db.Decimal(10, 2) // percent (0-100) or flat ₹ off
  planName      String? // BASIC | PREMIUM | null = all
  durationDays  Int? // 30/90/... | null = all
  startsAt      DateTime
  endsAt        DateTime
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  payments Payment[]

  @@index([active, startsAt, endsAt])
}

model Payment {
  id                String        @id @default(uuid())
  lawyerId          String
  lawyer            Lawyer        @relation(fields: [lawyerId], references: [id])
  planName          String
  amount            Decimal       @db.Decimal(10, 2) // final charged amount (after any offer)
  listAmount        Decimal?      @db.Decimal(10, 2) // tier price before discount
  offerId           String?
  offer             Offer?        @relation(fields: [offerId], references: [id])
  offerName         String? // snapshot of the offer name at purchase time
  durationDays      Int
  provider          String        @default("razorpay")
  providerOrderId   String        @unique
  providerPaymentId String?
  status            PaymentStatus @default(CREATED)
  invoiceNo         String?       @unique // GST invoice number, assigned on first download
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([lawyerId, status])
}

model Lead {
  id           String        @id @default(uuid())
  clientId     String
  client       User          @relation("ClientLeads", fields: [clientId], references: [id])
  lawyerId     String
  lawyer       Lawyer        @relation("LawyerLeads", fields: [lawyerId], references: [id])
  practiceArea String
  description  String
  status       LeadStatus    @default(NEW)
  createdAt    DateTime      @default(now())

  clientConfirmedAt DateTime? // client confirmed the lawyer actually made contact
  slaNudgedAt       DateTime? // lead-SLA reminder sent (once per lead)
  closedReason      String? // e.g. WITHDRAWN, HIRED, DECLINED, EXPIRED

  rating  Rating?
  history LeadHistory[]

  @@index([lawyerId, status])
}

model LeadHistory {
  id         String      @id @default(uuid())
  leadId     String
  lead       Lead        @relation(fields: [leadId], references: [id])
  fromStatus LeadStatus?
  toStatus   LeadStatus
  changedBy  String
  note       String?
  createdAt  DateTime    @default(now())

  @@index([leadId])
}

// "Contact us" submissions — triaged by admins under Client Queries.
model ContactQuery {
  id        String             @id @default(uuid())
  name      String
  email     String
  mobile    String?
  category  ContactCategory
  subject   String?
  message   String
  status    ContactQueryStatus @default(OPEN)
  adminNote String?
  userId    String? // set when the sender was signed in
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([status, createdAt])
}

// Criteria-based platform recognition (see docs/27-awards-and-recognition.md).
// Computed automatically per calendar year — never self-assigned.
model LawyerAward {
  id           String    @id @default(uuid())
  lawyerId     String
  lawyer       Lawyer    @relation(fields: [lawyerId], references: [id])
  type         AwardType
  year         Int
  title        String // display name, e.g. "Client's Choice"
  criteriaJson Json? // snapshot of the numbers that earned it
  createdAt    DateTime  @default(now())

  @@unique([lawyerId, type, year])
  @@index([lawyerId])
}

model Rating {
  id        String   @id @default(uuid())
  leadId    String   @unique
  lead      Lead     @relation(fields: [leadId], references: [id])
  lawyerId  String
  lawyer    Lawyer   @relation(fields: [lawyerId], references: [id])
  clientId  String
  client    User     @relation(fields: [clientId], references: [id])
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([lawyerId])
}

// ---------- Reference data: location, practice area, language, court ----------

model State {
  id        String     @id @default(uuid())
  name      String
  code      String     @unique
  districts District[]
  createdAt DateTime   @default(now())
}

model District {
  id      String @id @default(uuid())
  stateId String
  state   State  @relation(fields: [stateId], references: [id])
  name    String
  cities  City[]

  @@unique([stateId, name])
}

model City {
  id           String              @id @default(uuid())
  districtId   String
  district     District            @relation(fields: [districtId], references: [id])
  name         String
  lawyers      Lawyer[]
  offices      LawyerOffice[]
  serviceAreas LawyerServiceArea[]
  localities   Locality[]

  @@unique([districtId, name])
  @@index([name])
}

// Physical presence: a lawyer can have several offices; exactly one is primary.
// Map pins come from offices; Lawyer.cityId/lat/lng mirror the primary office.
model LawyerOffice {
  id          String  @id @default(uuid())
  lawyerId    String
  lawyer      Lawyer  @relation(fields: [lawyerId], references: [id])
  label       String? // "Main office", "High Court chamber"
  addressLine String?
  cityId      String
  city        City    @relation(fields: [cityId], references: [id])
  pincode     String? // 6-digit Indian PIN
  landmark    String?
  localityId  String? // metro locality tag (optional; see Locality)
  locality    Locality? @relation(fields: [localityId], references: [id])
  latitude    Float?
  longitude   Float?
  isPrimary   Boolean  @default(false)
  photoUrls   String[] @default([]) // office photos (max 3, enforced in service)

  @@index([lawyerId])
  @@index([cityId])
}

// Lead-serving territory: cities where the lawyer accepts leads.
// Search matches ACTIVE service areas; capped per plan (see SubscriptionPlanPrice).
model LawyerServiceArea {
  lawyerId String
  lawyer   Lawyer  @relation(fields: [lawyerId], references: [id])
  cityId   String
  city     City    @relation(fields: [cityId], references: [id])
  active   Boolean @default(true)

  @@id([lawyerId, cityId])
  @@index([cityId, active])
}

model PracticeArea {
  id      String               @id @default(uuid())
  name    String               @unique
  slug    String               @unique
  lawyers LawyerPracticeArea[]
}

model LawyerPracticeArea {
  lawyerId       String
  lawyer         Lawyer       @relation(fields: [lawyerId], references: [id])
  practiceAreaId String
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id])
  proficiency    Int?
  skills         String[]

  @@id([lawyerId, practiceAreaId])
  @@index([practiceAreaId])
}

model Language {
  id      String           @id @default(uuid())
  name    String           @unique
  code    String           @unique
  lawyers LawyerLanguage[]
}

model LawyerLanguage {
  lawyerId   String
  lawyer     Lawyer   @relation(fields: [lawyerId], references: [id])
  languageId String
  language   Language @relation(fields: [languageId], references: [id])

  @@id([lawyerId, languageId])
}

model Court {
  id      String        @id @default(uuid())
  name    String        @unique
  code    String        @unique
  type    String
  lawyers LawyerCourt[]
}

model LawyerCourt {
  lawyerId String
  lawyer   Lawyer @relation(fields: [lawyerId], references: [id])
  courtId  String
  court    Court  @relation(fields: [courtId], references: [id])

  @@id([lawyerId, courtId])
  @@index([courtId])
}

// Every homepage legal question — demand intelligence + KB gap analysis (docs/12).
model AiIntakeLog {
  id           String   @id @default(uuid())
  question     String
  topicKey     String
  matched      Boolean
  practiceArea String?
  aiUsed       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([topicKey, createdAt])
  @@index([matched, createdAt])
}

// ---------- Property Document Check (docs/29) ----------

enum PropertyCaseStatus {
  OPEN
  ANALYZED
  LAWYER_REVIEW
  CLOSED
}

model PropertyCase {
  id              String             @id @default(uuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  state           String
  city            String
  transactionType String // FLAT_PURCHASE | SITE_PURCHASE | RESALE_HOUSE | AGRICULTURAL_LAND | OTHER
  status          PropertyCaseStatus @default(OPEN)
  reportJson      Json? // deterministic checklist report (verbatim, audit-separated from lawyer advice)
  leadId          String? // set when the client requests a lawyer opinion
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  documents       PropertyCaseDocument[]

  @@index([userId, status])
}

model PropertyCaseDocument {
  id        String       @id @default(uuid())
  caseId    String
  case      PropertyCase @relation(fields: [caseId], references: [id])
  docType   String // checklist item key, e.g. saleDeed, ec, khataCertificate
  provided  Boolean      @default(true) // ticked as "I have this" (upload optional in P0)
  fileUrl   String?
  createdAt DateTime     @default(now())

  @@unique([caseId, docType])
}

// Seeded per state × transaction type; 'ANY' state matches everywhere. Admin CRUD in P1.
model PropertyChecklist {
  id              String @id @default(uuid())
  state           String
  transactionType String
  items           Json // [{ key, label, why, required }]

  @@unique([state, transactionType])
}

// ---------- Document marketplace ----------

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model DocumentCategory {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  description String?
  templates   DocumentTemplate[]
}

model DocumentTemplate {
  id            String             @id @default(uuid())
  categoryId    String
  category      DocumentCategory   @relation(fields: [categoryId], references: [id])
  title         String
  slug          String             @unique
  keywords      String[]
  price         Decimal            @db.Decimal(10, 2)
  schemaJson    Json
  bodyTemplate  String
  requiresStamp Boolean            @default(false)
  stampBasis    String?
  status        TemplateStatus     @default(DRAFT)
  version       Int                @default(1)
  language      String             @default("en")
  active        Boolean            @default(true)
  documents     CustomerDocument[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([categoryId, active])
}

model CustomerDocument {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  templateId      String
  template        DocumentTemplate @relation(fields: [templateId], references: [id])
  inputJson       Json
  contentHtml     String? // snapshot of the purchased document (frozen at payment)
  providerOrderId String?
  amount          Decimal?         @db.Decimal(10, 2)
  pdfUrl          String?
  status          DocumentStatus   @default(DRAFT)
  deliveryType    DeliveryType     @default(DIGITAL)
  eStamped        Boolean          @default(false)
  eSigned         Boolean          @default(false)
  stampDuty       Decimal?         @db.Decimal(10, 2)
  deliveryFee     Decimal?         @db.Decimal(10, 2)
  deliveryAddress Json?
  paymentId       String?
  lawyerId        String?
  reviewStatus    DocReviewStatus       @default(NONE)
  reviewFee       Decimal?              @db.Decimal(10, 2)
  lawyerPayout    Decimal?              @db.Decimal(10, 2)
  reviewOrderId   String?
  reviewPaymentId String?
  reviewEvents    DocumentReviewEvent[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId, status])
  @@index([reviewStatus])
}

// ---------- e-Sign / e-Stamp (vendor-agnostic) ----------

enum ESignStatus {
  PENDING
  SENT
  AWAITING_SIGNATURE
  SIGNED
  REJECTED
  EXPIRED
  FAILED
  CANCELLED
}

enum EStampStatus {
  PENDING
  SENT
  PAID
  STAMPED
  REJECTED
  EXPIRED
  FAILED
  CANCELLED
}

// Provider-independent e-sign request. `provider` records which adapter owns it
// so late webhooks route correctly even after the default provider changes.
model ESignRequest {
  id                String      @id @default(uuid())
  provider          String
  providerRequestId String?
  documentId        String
  userId            String
  status            ESignStatus @default(PENDING)
  signerEmail       String?
  callbackPayload   Json?
  signedDocumentUrl String?
  auditLog          Json? // append-only array of { at, event, status }
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([documentId])
  @@index([providerRequestId])
  @@index([status])
}

model EStampRequest {
  id                String       @id @default(uuid())
  provider          String
  stateCode         String
  documentId        String
  userId            String
  amount            Decimal      @db.Decimal(10, 2)
  status            EStampStatus @default(PENDING)
  providerRequestId String?
  certificateNumber String?
  certificateUrl    String?
  callbackPayload   Json?
  auditLog          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([documentId])
  @@index([providerRequestId])
  @@index([status])
}

enum DocReviewStatus {
  NONE
  REQUESTED
  IN_REVIEW
  APPROVED
  REJECTED
}

model DocumentReviewEvent {
  id         String           @id @default(uuid())
  documentId String
  document   CustomerDocument @relation(fields: [documentId], references: [id])
  actorId    String
  action     String // REQUESTED | CLAIMED | APPROVED | REJECTED | REVISION | COMMENT
  comment    String?
  createdAt  DateTime         @default(now())

  @@index([documentId, createdAt])
}

// Seeded per state x stampBasis; admin-editable. calcType: FLAT | PERCENT | SLAB.
model StampDutyRate {
  id           String   @id @default(uuid())
  state        String
  documentType String // matches DocumentTemplate.stampBasis
  calcType     String   @default("FLAT")
  flatAmount   Decimal? @db.Decimal(10, 2)
  percent      Decimal? @db.Decimal(5, 2)
  minAmount    Decimal? @db.Decimal(10, 2)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([state, documentType])
}

// ---------- Platform: bookmarks, notifications, audit ----------

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  lawyerId  String
  lawyer    Lawyer   @relation(fields: [lawyerId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, lawyerId])
  @@index([lawyerId])
}

// Immutable trail of every admin action (docs/10 — compliance).
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String // e.g. LAWYER_APPROVED, USER_SUSPENDED, SETTINGS_UPDATED
  entityType String?
  entityId   String?
  summary    String   @default("")
  oldValue   Json?
  newValue   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
}

// Admin-configurable platform settings (gateway keys, business knobs).
// Values override env vars; empty/missing rows fall back to process.env.
model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id])
  channel     NotificationChannel
  type        String
  payloadJson Json?
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  @@index([userId, readAt])
}

// Editable SEO copy per city × practice-area landing page (keeps content unique, not boilerplate).
model LandingContent {
  id           String   @id @default(uuid())
  citySlug     String
  practiceSlug String
  title        String // H1 override
  intro        String // unique SEO intro copy
  faqJson      Json? // [{ q, a }]
  updatedAt    DateTime @updatedAt

  @@unique([citySlug, practiceSlug])
}



// ─────────────────────────────────────────────────────────────
// Content Management System (CMS)
// Generic, admin-managed content store that replaces the static
// frontend legal-guides files. One polymorphic ContentItem model
// serves every content type; adding a new type is an enum value,
// not a new table. See docs/cms/README.md.
// ─────────────────────────────────────────────────────────────

enum ContentType {
  GUIDE // Legal awareness / how-to guides
  NEWS // Legal news updates
  JUDGMENT // Judgment / case-law summaries
  NOTIFICATION // Government notifications & circulars
  FAQ // Standalone FAQ entries
}

enum ContentStatus {
  DRAFT // being written
  IN_REVIEW // submitted for legal review
  PUBLISHED // live (visible when publishedAt <= now)
  ARCHIVED // retired, kept for history / SEO redirects
}

// Independent of the editorial workflow: tracks the *legal* review
// signal shown to readers (E-E-A-T). Defaults to "pending" so we never
// imply a review that has not happened.
enum ContentReviewState {
  PENDING_LEGAL_REVIEW // no advocate assigned yet -> "Reviewer: To Be Assigned"
  IN_LEGAL_REVIEW // an advocate is reviewing
  LEGALLY_REVIEWED // reviewed & signed off by the assigned reviewer
}

// A subject-matter reviewer (advocate) for E-E-A-T credibility.
// `lawyerId` is a soft reference to a verified Lawyer on the platform so a
// verified lawyer can later be promoted to a reviewer without a schema change.
model Reviewer {
  id               String        @id @default(uuid())
  name             String
  designation      String? // e.g. "Advocate, High Court of Karnataka"
  barCouncilNumber String? // e.g. "KAR/1234/2015"
  practiceAreas    String[] // e.g. ["property", "family"]
  biography        String?
  photoUrl         String?
  lawyerId         String?       @unique // soft link to a verified Lawyer (no hard FK by design)
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  contents         ContentItem[]

  @@index([active])
}

// Admin-managed taxonomy, scoped per content type so "family-law" can exist
// for GUIDE and independently for JUDGMENT without collisions.
model ContentCategory {
  id          String      @id @default(uuid())
  type        ContentType
  slug        String
  name        String
  description String?
  icon        String? // Icon component name (frontend inline SVG set)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([type, slug])
  @@index([type])
}

// The single polymorphic content record.
model ContentItem {
  id     String        @id @default(uuid())
  type   ContentType
  status ContentStatus @default(DRAFT)
  slug   String        @unique
  title  String
  excerpt String? // short summary / list teaser

  // Rendered body. `bodyHtml` is the generic render target; `sections`
  // holds the structured per-type payload (e.g. the 12-section guide
  // shape, judgment {court, citation}, notification {authority, number}).
  bodyHtml String  @default("")
  sections Json? // structured, type-specific content
  faqs     Json? // [{ q, a }] — powers FAQPage JSON-LD

  // SEO
  seoTitle         String?
  metaDescription  String?
  canonicalUrl     String?
  ogImageUrl       String?
  featuredImageUrl String?
  jsonLd           Json? // optional hand-authored JSON-LD override

  // Taxonomy & relations
  categorySlug       String? // -> ContentCategory(type, slug)
  tags               String[]
  practiceAreas      String[]
  states             String[] // state applicability (e.g. ["KA","MH"]; empty = all-India)
  relatedDocumentIds String[] // DocumentTemplate ids (marketplace cross-sell)
  relatedLawyerIds   String[] // Lawyer ids (surface verified lawyers)

  // Editorial / review
  authorName  String? @default("LawMitran Legal Content Team")
  reviewerId  String?
  reviewer    Reviewer?          @relation(fields: [reviewerId], references: [id])
  reviewState ContentReviewState @default(PENDING_LEGAL_REVIEW)

  // Publishing. A PUBLISHED item with a future publishedAt is effectively
  // scheduled: public queries filter on publishedAt <= now().
  publishedAt DateTime?
  createdById String?
  updatedById String?
  readMinutes Int?

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  revisions ContentRevision[]

  @@index([type, status])
  @@index([status, publishedAt])
  @@index([type, categorySlug])
}

// Append-only revision history: a full JSON snapshot is written before every
// update so any prior version can be inspected or restored.
model ContentRevision {
  id        String      @id @default(uuid())
  contentId String
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  editorId  String?
  note      String?
  snapshot  Json
  createdAt DateTime    @default(now())

  @@index([contentId, createdAt])
}

// Metro locality (Electronic City, Tambaram, Andheri...). Seeded only for big
// cities; powers the locality filter (ranking boost by centroid distance) on
// lawyer search, office tagging, and future locality SEO landing pages.
model Locality {
  id      String         @id @default(uuid())
  cityId  String
  city    City           @relation(fields: [cityId], references: [id])
  name    String
  slug    String
  lat     Float
  lng     Float
  offices LawyerOffice[]

  @@unique([cityId, slug])
  @@index([cityId])
}
