# ─────────────────────────────────────────────────────────────
# LawMitran Backend (NestJS + Prisma) — environment template
# Copy to backend/.env:   cp backend/.env.example backend/.env
# Loaded automatically by @nestjs/config and Prisma (cwd = backend/).
# This app owns its config — it does NOT read a root .env.
# ─────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001                                   # main.ts (default 3001)
FRONTEND_ORIGIN=http://localhost:3000       # CORS origin + email links (default http://localhost:3000)

# ── Database (Prisma) ────────────────────────────────────────
DATABASE_URL=postgresql://lawmitran:lawmitran@localhost:5432/lawmitran?schema=public

# ── Auth (JWT) ───────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m                   # default 15m
JWT_REFRESH_EXPIRES_IN=7d                    # default 7d
JWT_REFRESH_EXPIRES_IN_LONG=30d             # "remember me" refresh lifetime (default 30d)

# ── Object storage (MinIO / S3-compatible) ───────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1                          # default us-east-1
S3_BUCKET=lawmitran-documents               # default lawmitran-documents
S3_ACCESS_KEY=lawmitran
S3_SECRET_KEY=lawmitran123
S3_FORCE_PATH_STYLE=true                     # required for MinIO

# ── Rate limiting (default tier; auth routes set stricter limits) ─
RATE_LIMIT_MAX=100                           # default 100
RATE_LIMIT_WINDOW_MS=60000                   # default 60000

# ── Cache (Redis) ────────────────────────────────────────────
# NOTE: reserved. The Redis container runs in docker, but the backend has no
# Redis client yet — REDIS_URL is not consumed by current code. Kept for the
# container/env parity and planned use (cache/queue). Safe to leave as-is.
REDIS_URL=redis://localhost:6379

# ── Admin seed (prisma/seed.ts) ──────────────────────────────
ADMIN_EMAIL=admin@lawmitran.com
ADMIN_MOBILE=9000000000
ADMIN_PASSWORD=change-me-admin-password

# ── Award thresholds (lawyers/awards.service.ts) ─────────────
AWARD_CC_MIN_RATINGS=10
AWARD_CC_MIN_AVG=4.5
AWARD_TR_MIN_SERVED=25
AWARD_TR_MIN_CONFIRMED=15
AWARD_RS_MIN_RATINGS=20
AWARD_RS_MIN_AVG=4.0

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Platform settings (managed in the Admin console).
# These are primarily stored in the DB via Admin → Settings; the values below
# act only as a fallback/bootstrap read through process.env when no DB row
# exists (see modules/settings/settings.service.ts). Leave blank/unset to use
# the admin console. Do NOT commit real secrets — set them in backend/.env.
# ─────────────────────────────────────────────────────────────

# Payments — Razorpay
# PAYMENTS_MODE=test
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# CURRENCY=INR

# Email (SMTP) — unset = emails logged to backend console
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=LawMitran <no-reply@lawmitran.com>
# SUPPORT_EMAIL=support@lawmitran.com

# reCAPTCHA — off/unset = captcha skipped
# RECAPTCHA_ENABLED=false
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# SMS gateway — off = OTPs logged to backend console
# SMS_ENABLED=false
# SMS_PROVIDER=msg91
# SMS_API_KEY=
# SMS_SENDER_ID=LWMTRN
# SMS_OTP_TEMPLATE_ID=

# WhatsApp (placeholder integration)
# WHATSAPP_ENABLED=false
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_OTP_TEMPLATE=

# AI assistance (homepage legal-question box) — off = curated KB only
# AI_ENABLED=false
# AI_PROVIDER=openai
# AI_API_KEY=
# AI_MODEL=gpt-4o-mini

# Security & compliance
# ADMIN_2FA_ENABLED=false
# GRIEVANCE_OFFICER_NAME=
# GRIEVANCE_OFFICER_EMAIL=grievance@lawmitran.com

# Billing & GST (tax invoices)
# GSTIN=
# GST_LEGAL_NAME=
# GST_ADDRESS=
# GST_RATE=18
# INVOICE_PREFIX=LM

# Business rules (also readable directly by services)
# TRIAL_DAYS=30                 # lawyers.service.ts + settings registry
# RENEWAL_REMINDER_DAYS=30,15,0 # subscriptions.service.ts + settings registry
# LEAD_SLA_HOURS=48
